# Ignorar a pasta com os datasets pesados baixados pelo script
data/

# Ignorar arquivos gerados pelo sistema operacional
.DS_Store
Thumbs.db

# Ignorar arquivos temporários e de cache do Python
__pycache__/
*.py[cod]
*$py.class

# Ignorar ambientes virtuais do Python (caso você crie um no futuro)
venv/
env/
.venv/
